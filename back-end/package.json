{
  "name": "ayel-cams-back-end",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --maxWorkers=1",
    "test:watch": "vitest",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "tsx src/db/cli.ts up",
    "db:rollback": "tsx src/db/cli.ts down 1",
    "db:seed": "tsx src/db/cli.ts seed",
    "db:reset": "npm run db:rollback && npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "jsonwebtoken": "9.0.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/jsonwebtoken": "9.0.8",
    "@types/node": "22.13.10",
    "@types/pg": "^8.18.0",
    "@types/supertest": "6.0.2",
    "supertest": "7.1.4",
    "tsx": "4.19.3",
    "typescript": "5.8.2",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "qs": "6.14.2"
  }
}
