{
  "name": "ayel-cams",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "install:all": "npm --prefix back-end install && npm --prefix front-end install",
    "dev:back": "npm --prefix back-end run dev",
    "dev:front": "npm --prefix front-end run dev",
    "build:back": "npm --prefix back-end run build",
    "build:front": "npm --prefix front-end run build",
    "build": "npm run build:back && npm run build:front",
    "lint:back": "npm --prefix back-end run lint",
    "lint:front": "npm --prefix front-end run lint",
    "lint": "npm run lint:back && npm run lint:front",
    "test:back": "npm --prefix back-end run test",
    "test:front": "npm --prefix front-end run test",
    "test": "npm run test:back && npm run test:front",
    "db:up": "docker compose -f back-end/docker-compose.yml up -d postgres",
    "db:down": "docker compose -f back-end/docker-compose.yml down",
    "db:migrate": "npm --prefix back-end run db:migrate",
    "db:rollback": "npm --prefix back-end run db:rollback",
    "db:seed": "npm --prefix back-end run db:seed"
  }
}
